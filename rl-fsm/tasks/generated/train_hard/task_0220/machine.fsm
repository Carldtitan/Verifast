machine fsm_lock {
  in bit i0
  in bit i1
  out bit[1:0] o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 1
    when i1 -> S1
    when i0 -> S2
    when i0 -> S1
    else -> S0
  }
  state S1 {
    o0 = 0
    o1 = 1
    else -> S2
  }
  state S2 {
    o0 = 0
    o1 = 2
    when i0 -> S2
    when i0 -> S1
    else -> S1
  }
}
