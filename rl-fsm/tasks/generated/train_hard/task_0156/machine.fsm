machine fsm_lock {
  in bit i0
  out bit[1:0] o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 3
    o1 = 1
    else -> S1
  }
  state S1 {
    o0 = 3
    o1 = 3
    when i0 -> S3
    when i0 -> S2
    else -> S0
  }
  state S2 {
    o0 = 3
    o1 = 1
    when i0 -> S4
    else -> S0
  }
  state S3 {
    o0 = 3
    o1 = 3
    when i0 -> S3
    when i0 -> S1
    else -> S2
  }
  state S4 {
    o0 = 2
    o1 = 2
    when i0 -> S1
    else -> S3
  }
}
