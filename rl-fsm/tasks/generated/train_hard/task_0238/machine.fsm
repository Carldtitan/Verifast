machine fsm_hold {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 1
    when i1 -> S0
    else -> S0
  }
  state S1 {
    o0 = 1
    o1 = 0
    else -> S2
  }
  state S2 {
    o0 = 0
    o1 = 1
    when i1 -> S2
    when i2 -> S0
    when i2 -> S2
    else -> S2
  }
}
