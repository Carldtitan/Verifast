machine fsm_hold {
  in bit i0
  out bit[1:0] o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 0
    when i0 -> S0
    when i0 -> S0
    else -> S1
  }
  state S1 {
    o0 = 1
    o1 = 0
    else -> S1
  }
  state S2 {
    o0 = 0
    o1 = 0
    when i0 -> S1
    when i0 -> S1
    else -> S1
  }
}
