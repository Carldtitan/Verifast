machine fsm_scan {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 2
    when i2 -> S0
    else -> S2
  }
  state S1 {
    o0 = 0
    o1 = 3
    when i1 -> S1
    when i0 -> S3
    when i2 -> S3
    else -> S1
  }
  state S2 {
    o0 = 0
    o1 = 2
    when i2 -> S0
    when i1 -> S2
    when i1 -> S0
    else -> S0
  }
  state S3 {
    o0 = 0
    o1 = 2
    when i2 -> S1
    else -> S1
  }
}
