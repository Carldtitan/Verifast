machine fsm_done {
  in bit i0
  in bit i1
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 3
    when i1 -> S2
    when i0 -> S2
    when i0 -> S2
    else -> S2
  }
  state S1 {
    o0 = 1
    o1 = 3
    when i1 -> S5
    else -> S0
  }
  state S2 {
    o0 = 0
    o1 = 0
    when i0 -> S2
    when i1 -> S3
    else -> S4
  }
  state S3 {
    o0 = 1
    o1 = 3
    when i1 -> S0
    else -> S4
  }
  state S4 {
    o0 = 1
    o1 = 3
    when i0 -> S4
    when i0 -> S4
    else -> S1
  }
  state S5 {
    o0 = 0
    o1 = 2
    else -> S3
  }
  state S6 {
    o0 = 0
    o1 = 0
    when i0 -> S4
    else -> S1
  }
}
