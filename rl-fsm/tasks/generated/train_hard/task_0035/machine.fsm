machine fsm_lock {
  in bit i0
  in bit i1
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 0
    when i1 -> S1
    else -> S0
  }
  state S1 {
    o0 = 0
    o1 = 2
    else -> S1
  }
  state S2 {
    o0 = 0
    o1 = 0
    when i1 -> S2
    when i0 -> S0
    else -> S3
  }
  state S3 {
    o0 = 0
    o1 = 0
    else -> S3
  }
}
