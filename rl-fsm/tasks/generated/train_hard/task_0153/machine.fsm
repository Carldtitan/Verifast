machine fsm_lock {
  in bit i0
  in bit i1
  out bit o0
  reset = S0
  state S0 {
    o0 = 0
    else -> S3
  }
  state S1 {
    o0 = 0
    else -> S3
  }
  state S2 {
    o0 = 0
    when i0 -> S0
    else -> S3
  }
  state S3 {
    o0 = 0
    when i0 -> S4
    when i1 -> S0
    else -> S1
  }
  state S4 {
    o0 = 1
    else -> S1
  }
}
