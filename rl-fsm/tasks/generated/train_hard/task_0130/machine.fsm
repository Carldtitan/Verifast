machine fsm_idle {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 1
    else -> S3
  }
  state S1 {
    o0 = 0
    o1 = 1
    else -> S0
  }
  state S2 {
    o0 = 0
    o1 = 1
    when i0 -> S2
    when i1 -> S3
    when i2 -> S2
    else -> S0
  }
  state S3 {
    o0 = 0
    o1 = 1
    when i2 -> S2
    when i1 -> S0
    else -> S0
  }
}
