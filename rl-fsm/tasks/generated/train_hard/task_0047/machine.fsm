machine fsm_scan {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  reset = S0
  state S0 {
    o0 = 0
    else -> S3
  }
  state S1 {
    o0 = 0
    when i2 -> S1
    else -> S6
  }
  state S2 {
    o0 = 0
    when i1 -> S0
    when i1 -> S1
    when i0 -> S3
    else -> S3
  }
  state S3 {
    o0 = 1
    when i1 -> S5
    else -> S2
  }
  state S4 {
    o0 = 1
    when i1 -> S1
    when i2 -> S3
    when i1 -> S1
    else -> S4
  }
  state S5 {
    o0 = 1
    when i2 -> S3
    else -> S6
  }
  state S6 {
    o0 = 1
    when i0 -> S2
    else -> S4
  }
}
