machine fsm_load {
  in bit i0
  out bit[1:0] o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 3
    o1 = 1
    when i0 -> S1
    else -> S2
  }
  state S1 {
    o0 = 1
    o1 = 1
    when i0 -> S0
    else -> S2
  }
  state S2 {
    o0 = 1
    o1 = 1
    when i0 -> S1
    when i0 -> S2
    else -> S0
  }
}
