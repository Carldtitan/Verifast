machine fsm_run {
  in bit i0
  in bit i1
  in bit i2
  out bit[1:0] o0
  reset = S0
  state S0 {
    o0 = 2
    when i2 -> S1
    when i1 -> S3
    else -> S4
  }
  state S1 {
    o0 = 1
    when i1 -> S3
    when i0 -> S2
    when i2 -> S0
    else -> S2
  }
  state S2 {
    o0 = 3
    else -> S4
  }
  state S3 {
    o0 = 1
    when i1 -> S3
    when i1 -> S3
    when i1 -> S2
    else -> S0
  }
  state S4 {
    o0 = 0
    when i2 -> S1
    else -> S2
  }
}
