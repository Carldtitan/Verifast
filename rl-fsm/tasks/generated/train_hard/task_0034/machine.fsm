machine fsm_run {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 0
    else -> S2
  }
  state S1 {
    o0 = 0
    o1 = 0
    when i2 -> S1
    else -> S3
  }
  state S2 {
    o0 = 1
    o1 = 1
    else -> S4
  }
  state S3 {
    o0 = 1
    o1 = 1
    else -> S5
  }
  state S4 {
    o0 = 1
    o1 = 1
    when i2 -> S2
    else -> S2
  }
  state S5 {
    o0 = 1
    o1 = 1
    else -> S4
  }
}
