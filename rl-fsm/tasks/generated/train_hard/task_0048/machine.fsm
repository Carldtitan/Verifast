machine fsm_wait {
  in bit i0
  in bit i1
  out bit o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 1
    when i0 -> S0
    else -> S2
  }
  state S1 {
    o0 = 1
    o1 = 1
    when i0 -> S4
    else -> S1
  }
  state S2 {
    o0 = 0
    o1 = 1
    when i0 -> S4
    else -> S0
  }
  state S3 {
    o0 = 0
    o1 = 0
    when i1 -> S2
    else -> S4
  }
  state S4 {
    o0 = 0
    o1 = 1
    else -> S4
  }
}
