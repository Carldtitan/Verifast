machine fsm_lock {
  in bit i0
  out bit o0
  reset = S0
  state S0 {
    o0 = 1
    when i0 -> S3
    when i0 -> S1
    else -> S0
  }
  state S1 {
    o0 = 0
    when i0 -> S4
    when i0 -> S2
    when i0 -> S3
    else -> S4
  }
  state S2 {
    o0 = 0
    when i0 -> S3
    when i0 -> S4
    when i0 -> S1
    else -> S4
  }
  state S3 {
    o0 = 0
    when i0 -> S0
    when i0 -> S3
    when i0 -> S3
    else -> S4
  }
  state S4 {
    o0 = 1
    when i0 -> S3
    else -> S4
  }
}
