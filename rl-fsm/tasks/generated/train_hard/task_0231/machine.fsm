machine fsm_run {
  in bit i0
  in bit i1
  out bit[1:0] o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 1
    when i0 -> S4
    when i0 -> S0
    else -> S2
  }
  state S1 {
    o0 = 3
    o1 = 3
    else -> S5
  }
  state S2 {
    o0 = 3
    o1 = 2
    when i0 -> S0
    when i0 -> S4
    when i0 -> S1
    else -> S3
  }
  state S3 {
    o0 = 2
    o1 = 0
    when i1 -> S2
    when i0 -> S3
    else -> S4
  }
  state S4 {
    o0 = 1
    o1 = 1
    when i1 -> S5
    else -> S3
  }
  state S5 {
    o0 = 0
    o1 = 0
    else -> S2
  }
}
