machine fsm_load {
  in bit i0
  in bit i1
  in bit i2
  out bit[1:0] o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 2
    o1 = 0
    when i0 -> S0
    when i2 -> S0
    when i1 -> S0
    else -> S0
  }
  state S1 {
    o0 = 2
    o1 = 0
    else -> S1
  }
  state S2 {
    o0 = 2
    o1 = 0
    else -> S1
  }
}
