machine fsm_arm {
  in bit i0
  in bit i1
  out bit o0
  out bit o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 0
    when i0 -> S6
    else -> S2
  }
  state S1 {
    o0 = 1
    o1 = 0
    when i0 -> S4
    else -> S5
  }
  state S2 {
    o0 = 0
    o1 = 1
    else -> S6
  }
  state S3 {
    o0 = 1
    o1 = 1
    when i0 -> S6
    when i0 -> S4
    when i0 -> S1
    else -> S2
  }
  state S4 {
    o0 = 1
    o1 = 1
    when i1 -> S5
    else -> S0
  }
  state S5 {
    o0 = 0
    o1 = 0
    else -> S4
  }
  state S6 {
    o0 = 1
    o1 = 0
    when i0 -> S6
    when i1 -> S3
    when i1 -> S6
    else -> S3
  }
}
