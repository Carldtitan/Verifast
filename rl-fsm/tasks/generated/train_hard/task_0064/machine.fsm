machine fsm_arm {
  in bit i0
  in bit i1
  out bit[1:0] o0
  reset = S0
  state S0 {
    o0 = 0
    when i0 -> S0
    when i0 -> S6
    when i1 -> S5
    else -> S5
  }
  state S1 {
    o0 = 3
    when i1 -> S6
    when i1 -> S1
    when i0 -> S4
    else -> S4
  }
  state S2 {
    o0 = 1
    when i1 -> S6
    else -> S0
  }
  state S3 {
    o0 = 0
    else -> S3
  }
  state S4 {
    o0 = 2
    when i1 -> S4
    when i1 -> S1
    else -> S3
  }
  state S5 {
    o0 = 2
    when i1 -> S0
    when i1 -> S5
    when i0 -> S1
    else -> S0
  }
  state S6 {
    o0 = 2
    when i1 -> S0
    else -> S0
  }
}
