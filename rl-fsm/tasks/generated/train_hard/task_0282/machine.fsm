machine fsm_wait {
  in bit i0
  in bit i1
  out bit o0
  reset = S0
  state S0 {
    o0 = 0
    when i0 -> S2
    when i0 -> S1
    when i0 -> S0
    else -> S0
  }
  state S1 {
    o0 = 1
    when i1 -> S3
    when i0 -> S3
    else -> S0
  }
  state S2 {
    o0 = 0
    when i0 -> S0
    when i0 -> S2
    when i0 -> S1
    else -> S3
  }
  state S3 {
    o0 = 0
    when i0 -> S2
    else -> S1
  }
}
