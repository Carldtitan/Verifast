machine fsm_wait {
  in bit i0
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 2
    else -> S1
  }
  state S1 {
    o0 = 0
    o1 = 2
    when i0 -> S2
    when i0 -> S3
    else -> S2
  }
  state S2 {
    o0 = 1
    o1 = 3
    else -> S0
  }
  state S3 {
    o0 = 1
    o1 = 3
    when i0 -> S1
    else -> S2
  }
}
