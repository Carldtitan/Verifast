machine fsm_idle {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 3
    when i1 -> S2
    else -> S2
  }
  state S1 {
    o0 = 1
    o1 = 1
    when i2 -> S4
    when i0 -> S0
    else -> S2
  }
  state S2 {
    o0 = 0
    o1 = 1
    when i2 -> S3
    when i1 -> S0
    else -> S4
  }
  state S3 {
    o0 = 0
    o1 = 3
    else -> S3
  }
  state S4 {
    o0 = 0
    o1 = 3
    when i0 -> S0
    when i0 -> S2
    else -> S2
  }
}
