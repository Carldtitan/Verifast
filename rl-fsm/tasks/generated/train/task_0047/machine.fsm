machine fsm_hold {
  in bit i0
  in bit i1
  in bit i2
  out bit o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 1
    o1 = 1
    else -> S1
  }
  state S1 {
    o0 = 0
    o1 = 3
    when i2 -> S2
    when i0 -> S2
    else -> S2
  }
  state S2 {
    o0 = 0
    o1 = 3
    when i1 -> S1
    else -> S2
  }
}
