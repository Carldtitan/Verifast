machine fsm_done {
  in bit i0
  out bit[1:0] o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 2
    o1 = 0
    when i0 -> S5
    else -> S0
  }
  state S1 {
    o0 = 2
    o1 = 3
    when i0 -> S0
    when i0 -> S6
    when i0 -> S2
    else -> S3
  }
  state S2 {
    o0 = 1
    o1 = 3
    when i0 -> S1
    when i0 -> S0
    when i0 -> S1
    else -> S0
  }
  state S3 {
    o0 = 2
    o1 = 3
    when i0 -> S8
    when i0 -> S4
    when i0 -> S0
    else -> S4
  }
  state S4 {
    o0 = 2
    o1 = 3
    when i0 -> S3
    else -> S0
  }
  state S5 {
    o0 = 3
    o1 = 2
    else -> S5
  }
  state S6 {
    o0 = 3
    o1 = 3
    when i0 -> S6
    else -> S4
  }
  state S7 {
    o0 = 0
    o1 = 1
    when i0 -> S4
    when i0 -> S6
    else -> S3
  }
  state S8 {
    o0 = 1
    o1 = 3
    else -> S1
  }
}
