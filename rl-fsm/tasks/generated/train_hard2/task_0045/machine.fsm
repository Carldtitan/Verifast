machine fsm_fire {
  in bit i0
  in bit i1
  in bit i2
  out bit[1:0] o0
  reset = S0
  state S0 {
    o0 = 2
    when i1 -> S2
    when i0 -> S2
    when i1 -> S5
    else -> S5
  }
  state S1 {
    o0 = 0
    when i1 -> S5
    when i0 -> S0
    else -> S3
  }
  state S2 {
    o0 = 2
    else -> S4
  }
  state S3 {
    o0 = 1
    else -> S1
  }
  state S4 {
    o0 = 3
    when i1 -> S2
    when i0 -> S3
    else -> S0
  }
  state S5 {
    o0 = 0
    else -> S0
  }
}
