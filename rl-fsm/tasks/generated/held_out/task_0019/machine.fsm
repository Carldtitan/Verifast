machine fsm_idle {
  in bit i0
  in bit i1
  out bit[1:0] o0
  out bit[1:0] o1
  reset = S0
  state S0 {
    o0 = 0
    o1 = 3
    when i0 -> S2
    else -> S0
  }
  state S1 {
    o0 = 3
    o1 = 0
    when i1 -> S0
    when i1 -> S0
    else -> S2
  }
  state S2 {
    o0 = 0
    o1 = 0
    when i1 -> S1
    else -> S1
  }
}
