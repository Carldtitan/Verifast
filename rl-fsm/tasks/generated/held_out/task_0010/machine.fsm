machine fsm_arm {
  in bit i0
  in bit i1
  in bit i2
  out bit[1:0] o0
  reset = S0
  state S0 {
    o0 = 1
    when i0 -> S2
    else -> S4
  }
  state S1 {
    o0 = 0
    when i2 -> S3
    else -> S0
  }
  state S2 {
    o0 = 2
    when i0 -> S4
    else -> S2
  }
  state S3 {
    o0 = 2
    when i1 -> S1
    else -> S3
  }
  state S4 {
    o0 = 2
    else -> S1
  }
}
